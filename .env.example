# Telegram Bot API credentials (required for alerts)
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# HTTP server port (default 3000)
PORT=3000

# Polling interval in milliseconds (clamped to 5000-10000, default 7000)
POLL_INTERVAL_MS=7000

# Default spread threshold percentage (can be changed at runtime via dashboard)
SPREAD_THRESHOLD=0.5
